modules = ["python-3.11", "python3", "nodejs-20", "postgresql-16"]

[nix]
channel = "stable-24_05"
packages = ["freetype", "gitFull", "glibcLocales", "lcms2", "libimagequant", "libjpeg", "libtiff", "libwebp", "libxcrypt", "openjpeg", "openssl", "playwright-driver", "postgresql", "postgresql_16", "tcl", "tk", "zlib", "nss", "nspr", "at-spi2-atk", "cups", "libdrm", "mesa", "xorg.libXcomposite", "xorg.libXdamage", "xorg.libXrandr", "xorg.libxcb", "xorg.libX11", "xorg.libXext", "xorg.libXfixes", "alsa-lib", "pango", "cairo", "expat", "glib", "dbus", "gtk3", "libxkbcommon", "xorg.libXi", "xorg.libXtst", "xorg.libXScrnSaver", "xorg.libXcursor"]

[deployment]
deploymentTarget = "autoscale"
run = ["gunicorn", "-c", "gunicorn_config.py", "main:app"]

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "fuser -k 5000/tcp 2>/dev/null; sleep 1; gunicorn -c gunicorn_config.py main:app"
waitForPort = 5000

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 8000
externalPort = 8000

[agent]
integrations = ["python_openai:1.0.0", "dropbox:1.0.0", "python_openai_ai_integrations:1.0.0"]

[userenv]

